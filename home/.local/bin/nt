#!/usr/bin/env bash

function main() {
  local dir="$PWD"
  local project_root="$HOME/Projects"

  if (($#)); then
    local arg="$1"
    shift

    if [[ -d $arg ]]; then
      dir="$arg"
    elif [[ -d $project_root/$arg ]]; then
      dir="$project_root/$arg"
    else
      local select_name
      # shellcheck disable=SC2010
      select_name=$(ls -1 "$project_root" 2>/dev/null | grep -i "$arg" | fzf --select-1 --exit-0)

      if [[ -z $select_name ]]; then
        echo "No such dir/project matching '$arg' found in $project_root" >&2
        return 1
      fi
      dir="$project_root/$select_name"
    fi
  fi

  local window_name
  window_name="${dir##*/}"
  if [[ $dir == "$project_root" ]]; then
    window_name="${project_root##*/}"
  fi
  if [[ $dir == "$HOME" ]]; then
    window_name="~"
  fi
  if [[ -n $window_name ]]; then
    window_name=${dir//*/}
  fi

  tmux new-window -c "$dir" -n "$window_name" "$@"

  local current_window_id
  current_window_id=$(tmux display-message -t "$TMUX_PANE" -p '#{window_id}')
  local active_option
  active_option="@starship-active-${current_window_id}"
  tmux set-option -g "$active_option" "1"
}

main "$@"
