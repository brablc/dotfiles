#!/bin/bash

LONG_RUN_SECS=5

function main() {
  local current_window_id current_pane_id is_active_window
  current_window_id=$(tmux display-message -t "$TMUX_PANE" -p '#{window_id}')
  current_pane_id=$(tmux display-message -t "$TMUX_PANE" -p '#{pane_id}')
  is_active_window=$(tmux display-message -t "$TMUX_PANE" -p '#{window_active}')

  # Use tmux user options to store timing info per pane
  local timing_option="@starship-timing-${current_pane_id}"
  local active_option="@starship-active-${current_pane_id}"
  local previous_timing current_timestamp was_active

  previous_timing=$(tmux show-option -gqv "$timing_option" 2>/dev/null || echo "")
  was_active=$(tmux show-option -gqv "$active_option" 2>/dev/null || echo "0")
  current_timestamp=$(date +%s)

  local style='bg=default'

  # If window just became active, reset timing
  if [[ $is_active_window == "1" && $was_active == "0" ]]; then
    echo "#t $TMUX_PANE $current_window_id - window became active, resetting timing" >&2
    # Reset timing when window becomes active
    tmux set-option -g "$timing_option" "$current_timestamp"
  elif [[ $is_active_window == "1" ]]; then
    # Window is active - always use default style
    style='bg=default'
    # Update timing for active window
    tmux set-option -g "$timing_option" "$current_timestamp"
  elif [[ -n $previous_timing ]]; then
    # Window is not active - check timing for background indication
    local previous_timestamp time_diff
    previous_timestamp="$previous_timing"
    time_diff=$((current_timestamp - previous_timestamp))

    if ((time_diff > LONG_RUN_SECS)); then
      style='bg=red'
    fi
  else
    # No previous timing and not active - set initial timing
    tmux set-option -g "$timing_option" "$current_timestamp"
  fi

  # Store current active state for next run
  tmux set-option -g "$active_option" "$is_active_window"

  # Apply window style to current window only
  # Use -q to suppress errors if window doesn't exist
  tmux set-window-option -qt "$current_window_id" window-status-current-style "$style" 2>/dev/null || true
  tmux set-window-option -qt "$current_window_id" window-status-style "$style" 2>/dev/null || true

  # Generate and set pane title
  starship_raw=$(starship prompt --profile tmux_title)
  starship_output=$(convert_colors "$starship_raw")

  tmux set-option -t "$TMUX_PANE" -p automatic-rename off
  tmux select-pane -t "$TMUX_PANE" -T "$starship_output"
}

# Convert ANSI color codes to tmux format using awk
function convert_colors() {
  echo "$1" | awk '
  BEGIN {
    # Color mapping arrays
    colors[30] = "black"
    colors[31] = "red"
    colors[32] = "green"
    colors[33] = "yellow"
    colors[34] = "blue"
    colors[35] = "magenta"
    colors[36] = "cyan"
    colors[37] = "white"
    colors[90] = "brightblack"
    colors[91] = "brightred"
    colors[92] = "brightgreen"
    colors[93] = "brightyellow"
    colors[94] = "brightblue"
    colors[95] = "brightmagenta"
    colors[96] = "brightcyan"
    colors[97] = "brightwhite"
  }
  {
    # Remove starship brackets
    gsub(/\\\[/, "")
    gsub(/\\\]/, "")

    # Convert ANSI escape sequences to tmux format
    # Reset codes
    gsub(/\x1b\[0?m/, "#[default]")

    # Bold
    gsub(/\x1b\[1m/, "#[bold]")

    # Bold + standard colors (1;3x)
    for (i = 30; i <= 37; i++) {
      gsub("\x1b\\[1;" i "m", "#[bold,fg=" colors[i] "]")
    }

    # Standard and bright colors
    for (i = 30; i <= 37; i++) {
      gsub("\x1b\\[" i "m", "#[fg=" colors[i] "]")
    }
    for (i = 90; i <= 97; i++) {
      gsub("\x1b\\[" i "m", "#[fg=" colors[i] "]")
    }

    # 256 colors (38;5;n)
    gsub(/\x1b\[38;5;([0-9]+)m/, "#[fg=colour\\1]")

    # RGB colors (38;2;r;g;b) - convert to hex
    while (match($0, /\x1b\[38;2;([0-9]+);([0-9]+);([0-9]+)m/)) {
      r = substr($0, RSTART + 7, RLENGTH - 8)
      split(r, rgb, ";")
      hex = sprintf("#[fg=#%02x%02x%02x]", rgb[1], rgb[2], rgb[3])
      gsub(/\x1b\[38;2;[0-9]+;[0-9]+;[0-9]+m/, hex, $0)
      break
    }

    # Clean up any remaining escape sequences
    gsub(/\x1b\[[0-9;]*m/, "")

    # Trim whitespace
    gsub(/^[[:space:]]+|[[:space:]]+$/, "")

    print
  }'
}

main "$@"
